# ==========================================
# 微信公众号运营平台 — 环境变量模板
# 复制为 .env 并填入真实值
# ==========================================

# --- PostgreSQL ---
DATABASE_URL="postgresql://wxgzh:wxgzh123@localhost:5432/wxgzh_dev?schema=public"

# --- Redis ---
REDIS_URL="redis://:wxgzh_redis@localhost:6379/0"

# --- JWT ---
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7200"

# --- Encryption (AES-256-GCM, 32 bytes base64) ---
ENCRYPTION_KEY="change-me-to-a-random-32-byte-base64-string"

# --- WeChat Open Platform ---
WECHAT_COMPONENT_APP_ID="wx0000000000000000"
WECHAT_COMPONENT_APP_SECRET="your-component-appsecret"
WECHAT_TOKEN="your-token-for-message-verification"
WECHAT_ENCODING_AES_KEY="your-43-char-encoding-aes-key"

# --- MinIO / OSS ---
OSS_ENDPOINT="localhost"
OSS_PORT="9000"
OSS_ACCESS_KEY="minioadmin"
OSS_SECRET_KEY="minioadmin"
OSS_BUCKET="wxgzh-materials"
OSS_USE_SSL="false"

# --- App ---
APP_PORT="3000"
APP_HOST="0.0.0.0"
NODE_ENV="development"
