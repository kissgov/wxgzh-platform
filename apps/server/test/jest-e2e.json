{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e.spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@wxgzh/shared$": "<rootDir>/../../packages/shared/src"
  },
  "testTimeout": 30000,
  "setupFiles": ["<rootDir>/e2e/helpers/setup-env.ts"]
}
