{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["@typescript-eslint", "local-rules"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "prettier"
  ],
  "env": {
    "node": true,
    "browser": true,
    "es2022": true
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "warn",
    "prefer-const": "warn",
    "local-rules/no-any-input": "error"
  },
  "overrides": [
    {
      "files": ["**/*.dto.ts", "**/integrations/**/*.controller.ts"],
      "rules": {
        "local-rules/no-any-input": "off"
      }
    }
  ],
  "ignorePatterns": ["dist", "node_modules", ".turbo", "coverage"]
}
